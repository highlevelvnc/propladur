# Google Analytics 4 — formato G-XXXXXXX
# Obter em https://analytics.google.com → criar propriedade → Stream → Measurement ID
NEXT_PUBLIC_GA_ID=

# Meta (Facebook/Instagram) Pixel — id numérico
# Obter em Meta Business Manager → Events Manager → Pixels → ID
NEXT_PUBLIC_META_PIXEL_ID=
